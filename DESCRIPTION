Package: diffdriver
Type: Package
Title: Identify Differential Selection
Version: 0.1.7
Authors@R: c(
    person("Siming", "Zhao", , "siming.zhao@dartmouth.edu", role = c("aut", "cre")),
    person("Jie", "Zhou", role = "aut"),
    person("Qirui", "Zhang", role = "aut")
